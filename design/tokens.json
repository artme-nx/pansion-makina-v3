{
  "$schema": "https://design-tokens.org/schema.json",
  "primitive": {
    "color": {
      "stone": {
        "50": { "$value": "#FBF7EF", "$type": "color" },
        "100": { "$value": "#F3ECDC", "$type": "color" },
        "200": { "$value": "#E6DBC3", "$type": "color" },
        "300": { "$value": "#D2C3A0", "$type": "color" }
      },
      "marina": {
        "950": { "$value": "#0D1F2D", "$type": "color" },
        "800": { "$value": "#15384C", "$type": "color" },
        "600": { "$value": "#245470", "$type": "color" },
        "400": { "$value": "#4C7C99", "$type": "color" }
      },
      "brass": {
        "500": { "$value": "#B8863F", "$type": "color" },
        "700": { "$value": "#8A6329", "$type": "color" }
      },
      "terracotta": {
        "500": { "$value": "#C6552E", "$type": "color" },
        "700": { "$value": "#963E20", "$type": "color" },
        "900": { "$value": "#4E1F10", "$type": "color" }
      }
    },
    "font": {
      "display": { "$value": "var(--font-newsreader), 'Newsreader', Georgia, serif", "$type": "fontFamily" },
      "sans": { "$value": "var(--font-inter), system-ui, sans-serif", "$type": "fontFamily" },
      "mono": { "$value": "var(--font-space-mono), 'SF Mono', monospace", "$type": "fontFamily" }
    },
    "motion": {
      "duration": {
        "micro": { "$value": "160ms", "$type": "duration" },
        "base": { "$value": "320ms", "$type": "duration" },
        "lift": { "$value": "420ms", "$type": "duration" },
        "reveal": { "$value": "1s", "$type": "duration" }
      },
      "ease": {
        "out-expo": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$type": "cubicBezier" },
        "swing": { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)", "$type": "cubicBezier" }
      }
    },
    "tracking": {
      "display": { "$value": "-0.01em", "$type": "dimension" },
      "label": { "$value": "0.22em", "$type": "dimension" }
    }
  },
  "semantic": {
    "background": { "$value": "{primitive.color.stone.50}", "$type": "color" },
    "foreground": { "$value": "{primitive.color.marina.950}", "$type": "color" },
    "card": { "$value": "{primitive.color.stone.100}", "$type": "color" },
    "card-foreground": { "$value": "{primitive.color.marina.950}", "$type": "color" },
    "popover": { "$value": "{primitive.color.stone.50}", "$type": "color" },
    "popover-foreground": { "$value": "{primitive.color.marina.950}", "$type": "color" },
    "primary": { "$value": "{primitive.color.marina.950}", "$type": "color" },
    "primary-foreground": { "$value": "{primitive.color.stone.50}", "$type": "color" },
    "secondary": { "$value": "{primitive.color.stone.200}", "$type": "color" },
    "secondary-foreground": { "$value": "{primitive.color.marina.950}", "$type": "color" },
    "muted": { "$value": "{primitive.color.stone.100}", "$type": "color" },
    "muted-foreground": { "$value": "{primitive.color.marina.600}", "$type": "color" },
    "accent": { "$value": "{primitive.color.stone.200}", "$type": "color" },
    "accent-foreground": { "$value": "{primitive.color.marina.950}", "$type": "color" },
    "destructive": { "$value": "{primitive.color.terracotta.700}", "$type": "color" },
    "border": { "$value": "{primitive.color.stone.300}", "$type": "color" },
    "input": { "$value": "{primitive.color.stone.300}", "$type": "color" },
    "ring": { "$value": "{primitive.color.brass.500}", "$type": "color" },
    "radius": { "$value": "0.5rem", "$type": "dimension" },
    "marina": { "$value": "{primitive.color.marina.800}", "$type": "color" },
    "marina-deep": { "$value": "{primitive.color.marina.950}", "$type": "color" },
    "brass": { "$value": "{primitive.color.brass.500}", "$type": "color" },
    "brass-dim": { "$value": "{primitive.color.brass.700}", "$type": "color" },
    "terracotta": { "$value": "{primitive.color.terracotta.500}", "$type": "color" },
    "terracotta-deep": { "$value": "{primitive.color.terracotta.700}", "$type": "color" },
    "surface-line": { "$value": "{primitive.color.stone.300}", "$type": "color" },
    "type-display": { "$value": "{primitive.font.display}", "$type": "fontFamily" },
    "type-body": { "$value": "{primitive.font.sans}", "$type": "fontFamily" },
    "type-label": { "$value": "{primitive.font.mono}", "$type": "fontFamily" },
    "ease-reveal": { "$value": "{primitive.motion.ease.out-expo}", "$type": "cubicBezier" },
    "ease-swing": { "$value": "{primitive.motion.ease.swing}", "$type": "cubicBezier" },
    "duration-micro": { "$value": "{primitive.motion.duration.micro}", "$type": "duration" },
    "duration-base": { "$value": "{primitive.motion.duration.base}", "$type": "duration" },
    "duration-lift": { "$value": "{primitive.motion.duration.lift}", "$type": "duration" },
    "duration-reveal": { "$value": "{primitive.motion.duration.reveal}", "$type": "duration" },
    "tracking-display": { "$value": "{primitive.tracking.display}", "$type": "dimension" },
    "tracking-label": { "$value": "{primitive.tracking.label}", "$type": "dimension" }
  },
  "component": {
    "hero": {
      "title-size": { "$value": "clamp(2.75rem, 7vw, 5.5rem)", "$type": "dimension" },
      "title-leading": { "$value": "1.02", "$type": "number" },
      "kicker-size": { "$value": "0.72rem", "$type": "dimension" }
    },
    "pegboard": {
      "hole-color": { "$value": "{primitive.color.marina.800}", "$type": "color" },
      "panel-bg": { "$value": "{primitive.color.stone.200}", "$type": "color" },
      "peg-color": { "$value": "{primitive.color.brass.500}", "$type": "color" },
      "fob-shadow": { "$value": "0 14px 24px -10px rgba(13, 31, 45, 0.45)", "$type": "shadow" }
    },
    "button": {
      "primary-bg": { "$value": "{primitive.color.terracotta.500}", "$type": "color" },
      "primary-fg": { "$value": "{primitive.color.stone.50}", "$type": "color" },
      "primary-hover-bg": { "$value": "{primitive.color.terracotta.700}", "$type": "color" },
      "primary-hover-fg": { "$value": "{primitive.color.stone.50}", "$type": "color" },
      "ghost-border": { "$value": "{primitive.color.marina.400}", "$type": "color" },
      "ghost-hover-border": { "$value": "{primitive.color.marina.950}", "$type": "color" }
    }
  }
}
